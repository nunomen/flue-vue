{
	"name": "@nunomen/flue-vue",
	"version": "0.0.0",
	"private": false,
	"license": "Apache-2.0",
	"type": "module",
	"packageManager": "pnpm@10.30.0",
	"engines": {
		"node": ">=22.12.0"
	},
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		}
	},
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"files": [
		"dist",
		"README.md",
		"LICENSE",
		"NOTICE"
	],
	"scripts": {
		"build": "tsc -p tsconfig.build.json",
		"typecheck": "tsc --noEmit",
		"prepack": "pnpm run build",
		"test": "vitest run",
		"test:watch": "vitest",
		"test:type": "vitest run --typecheck.only",
		"check": "pnpm run typecheck && pnpm run build && pnpm run test && pnpm run test:type"
	},
	"peerDependencies": {
		"@flue/sdk": ">=1.0.0-beta.3 <1.0.0",
		"vue": ">=3.5.0"
	},
	"dependencies": {},
	"devDependencies": {
		"@flue/sdk": "^1.0.0-beta.6",
		"@vue/test-utils": "^2.4.8",
		"jsdom": "^27.4.0",
		"typescript": "~5.9.3",
		"vitest": "^4.1.5",
		"vue": "^3.5.33",
		"vue-tsc": "^3.2.7"
	}
}
